        <mxCell id="rt" value="&lt;b style=&quot;font-size:16px&quot;&gt;FraudGuard — Rôles et Timeline&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#666&quot;&gt;8h30 → 15h (6h30, pas de pause) | Présentation à 15h&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fontColor=#1a1a2e;" vertex="1" parent="1"><mxGeometry x="350" y="10" width="500" height="40" as="geometry" /></mxCell>
        <mxCell id="r1" value="&lt;b&gt;Rôle 1&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;color:#2E7D32&quot;&gt;Data Scientist&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#888&quot;&gt;Le Cerveau&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="65" width="240" height="200" as="geometry" /></mxCell>
        <mxCell id="r1c" value="&lt;font style=&quot;font-size:10px&quot;&gt;🎯 &lt;b&gt;Créer .env&lt;/b&gt; (+ AWS creds)&lt;br&gt;🔍 Vérifier ML + MLflow + Registry&lt;br&gt;🔧 Config MLflow → AWS S3&lt;br&gt;🔧 Ajouter /metrics Prometheus&lt;br&gt;🔧 README final&lt;br&gt;🌟 Bonus : human-in-the-loop&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="40" y="115" width="225" height="140" as="geometry" /></mxCell>
        <mxCell id="r2" value="&lt;b&gt;Rôle 2&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;color:#2E7D32&quot;&gt;Backend Eng.&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#888&quot;&gt;Le Guichetier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#4CAF50;fontSize=11;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="290" y="65" width="240" height="200" as="geometry" /></mxCell>
        <mxCell id="r2c" value="&lt;font style=&quot;font-size:10px&quot;&gt;🔍 Vérifier API + Dockerfiles&lt;br&gt;🔧 &lt;b&gt;Écrire tests pytest&lt;/b&gt;&lt;br&gt;🌟 Bonus : accès API (API key)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="300" y="115" width="220" height="140" as="geometry" /></mxCell>
        <mxCell id="r3" value="&lt;b&gt;Rôle 3&lt;/b&gt;&lt;br&gt;&lt;b style=&quot;color:#E65100&quot;&gt;Data Engineer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:8px;color:#888&quot;&gt;Le Logisticien&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;strokeWidth=2;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="550" y="65" width="240" height="200" as="geometry" /></mxCell>
        <mxCell id="r3c" value="&lt;font style=&quot;font-size:10px&quot;&gt;🔍 Vérifier DAG existant&lt;br&gt;🎯 &lt;b&gt;Créer DAG CT (Obj 8)&lt;/b&gt;&lt;br&gt;🌟 Bonus : données live, alerting&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="560" y="115" width="220" height="140" as="geometry" /></mxCell>
